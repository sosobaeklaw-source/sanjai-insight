# ============================================================================
# sanjai-insight Railway Production Environment Variables
# ============================================================================
# 이 템플릿을 Railway 환경변수 설정 시 참조하세요.
# 필수(REQUIRED) 변수가 없으면 시스템이 정상 작동하지 않습니다.
# ============================================================================

# ============================================================================
# SECTION 1: Telegram Bot (REQUIRED)
# ============================================================================
# Telegram 봇 토큰 및 대표님 Chat ID
# 얻는 법: @BotFather에서 봇 생성 후 토큰 발급
#         대표님 Chat ID는 @userinfobot에서 확인
# ============================================================================
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567890
TELEGRAM_CEO_CHAT_ID=123456789

# ============================================================================
# SECTION 2: LLM API Keys (REQUIRED)
# ============================================================================
# Claude (Anthropic) - Think/Propose 엔진용
# 얻는 법: https://console.anthropic.com/settings/keys
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Gemini (Google) - Marketing 엔진용 (선택)
# 얻는 법: https://makersuite.google.com/app/apikey
# ============================================================================
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================================
# SECTION 3: Database (REQUIRED)
# ============================================================================
# Railway는 자동으로 /data 볼륨을 마운트합니다.
# 로컬 개발 시에는 상대 경로 사용 가능
# ============================================================================
DATABASE_PATH=/data/insight.db

# ============================================================================
# SECTION 4: sanjai-agent 통합 (선택)
# ============================================================================
# sanjai-agent와 연동하여 사건 자동 처리
# Railway 배포 시 agent DB 경로 설정 필요
# ============================================================================
SANJAI_AGENT_DB_PATH=/data/agent/database.db
SANJAI_AGENT_VECTORDB_PATH=/data/agent/chroma_db
SANJAI_AGENT_TG_BOT_TOKEN=

# ============================================================================
# SECTION 5: OpenClaw 통합 (선택)
# ============================================================================
# 법원 문서 자동 수집 (openclaw-bridge 연동)
# ============================================================================
OPENCLAW_ENABLED=false
OPENCLAW_WEBHOOK_URL=

# ============================================================================
# SECTION 6: Obsidian Vault (선택)
# ============================================================================
# 볼트 경로 (로컬/네트워크 드라이브)
# Railway 배포 시 /data/vault 경로 사용 권장
# ============================================================================
OBSIDIAN_VAULT_PATH=/data/vault

# ============================================================================
# SECTION 7: Cost Control (REQUIRED)
# ============================================================================
# 월간 예산 (KRW)
# 이 금액을 초과하면 자동으로 배치 모드로 전환됩니다.
# ============================================================================
MONTHLY_BUDGET_KRW=50000

# ============================================================================
# SECTION 8: Runtime Environment (REQUIRED)
# ============================================================================
# Environment: development | production
# production 모드에서는 에러 메시지가 최소화되고 로깅이 강화됩니다.
# ============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================================================
# SECTION 9: Railway 전용 (자동 설정)
# ============================================================================
# Railway가 자동으로 설정하는 변수들
# 수동으로 설정할 필요 없음
# ============================================================================
# RAILWAY_ENVIRONMENT=production
# PORT=8000
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_ID=

# ============================================================================
# SECTION 10: 고급 설정 (선택)
# ============================================================================
# Worker 스레드 수 (기본: 1, Railway에서는 1 권장)
# ============================================================================
WORKER_THREADS=1

# ============================================================================
# 스케줄 설정 (기본값 사용 권장)
# config/schedule.yaml에서 관리되므로 환경변수로 오버라이드 불필요
# ============================================================================
# WATCH_CRON=0 9 * * *
# THINK_CRON=0 10 * * *
# DIAGNOSE_CRON=0 0 * * 0

# ============================================================================
# 보안 설정
# ============================================================================
# Agent 연동 시 서명 검증용 비밀키 (32자 이상)
# openssl rand -base64 32 로 생성
# ============================================================================
AGENT_BRIDGE_SECRET=

# ============================================================================
# 메트릭/모니터링 (선택)
# ============================================================================
# Prometheus/Grafana 연동 시 사용
# ============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090

# ============================================================================
# 설정 확인 체크리스트
# ============================================================================
# [ ] TELEGRAM_BOT_TOKEN 설정 완료
# [ ] TELEGRAM_CEO_CHAT_ID 설정 완료
# [ ] ANTHROPIC_API_KEY 설정 완료
# [ ] DATABASE_PATH 경로 확인 (/data/insight.db)
# [ ] MONTHLY_BUDGET_KRW 예산 설정 완료
# [ ] ENVIRONMENT=production 확인
# [ ] Railway 볼륨 마운트 확인 (/data)
# ============================================================================

# ============================================================================
# 주의사항
# ============================================================================
# 1. API 키는 절대 Git에 커밋하지 마세요.
# 2. Railway 환경변수는 UI에서 설정하고, 이 파일은 참조용입니다.
# 3. 프로덕션 배포 전 모든 필수 변수를 확인하세요.
# 4. MONTHLY_BUDGET_KRW는 실제 예산에 맞게 조정하세요.
# ============================================================================
