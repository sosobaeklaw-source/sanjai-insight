# sanjai-insight Environment Variables

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CEO_CHAT_ID=your_chat_id_here

# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Database
DATABASE_PATH=data/insight.db

# sanjai-agent Integration (읽기전용)
SANJAI_AGENT_DB_PATH=../sanjai-agent/data/database.db
SANJAI_AGENT_VECTORDB_PATH=../sanjai-agent/chroma_db
SANJAI_AGENT_TG_BOT_TOKEN=sanjai_agent_bot_token_here

# OpenClaw Integration (Optional)
OPENCLAW_ENABLED=false
OPENCLAW_WEBHOOK_URL=

# Obsidian Vault (Optional)
OBSIDIAN_VAULT_PATH=

# Cost Control
MONTHLY_BUDGET_KRW=50000

# Environment
ENVIRONMENT=development  # development, production
LOG_LEVEL=INFO

# Railway (Production only)
RAILWAY_ENVIRONMENT=production
PORT=8000
